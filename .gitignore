# pyenv
#   For a library or package, you might want to ignore these files since the user is
#   responsible for setting up their own environment. For a binary/app, they might
#   be useful to commit.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in git.
#   However, in case of collaboration, if having platform-specific dependencies or
#   dependencies on other packages, it might cause dependency resolving issues.
#Pipfile.lock

# poetry
#   Similar to Pipfile.lock, poetry.lock contains the exact dependency versions.
#   It is usually recommended to commit it.
#poetry.lock

# pdm
#   Similar to Pipfile.lock, pdm.lock contains the exact dependency versions.
#pdm.lock

# virtualenv
.venv
venv/
ENV/
env/
active_env/

